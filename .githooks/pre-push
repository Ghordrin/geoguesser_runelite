#!/bin/sh
#
# pre-push hook: block pushes to main/master if capture-tool code in
# GeoguessrPlugin.java is not gated behind RuneLiteProperties.isDevelopmentMode().
#
# Install once per clone:
#   git config core.hooksPath .githooks
#
# To bypass in an emergency (use sparingly):
#   git push --no-verify

PLUGIN="src/main/java/com/geoguessrrs/GeoguessrPlugin.java"
PROTECTED="main master"

current_branch=$(git symbolic-ref HEAD 2>/dev/null | sed 's|refs/heads/||')

for branch in $PROTECTED; do
    if [ "$current_branch" = "$branch" ]; then
        # Check whether capture references exist in the plugin file
        if grep -qE "captureOverlay|captureService|captureHotkeyListener" "$PLUGIN" 2>/dev/null; then
            # They exist — make sure they're all guarded
            if ! grep -q "DevMode.isEnabled" "$PLUGIN" 2>/dev/null; then
                echo ""
                echo "  PUSH BLOCKED: capture-tool code in $PLUGIN"
                echo "  is not gated behind RuneLiteProperties.isDevelopmentMode()."
                echo ""
                echo "  Either:"
                echo "    1. Wrap capture code in isDevelopmentMode() (see existing pattern)"
                echo "    2. Remove capture code before merging to $branch"
                echo ""
                exit 1
            fi
        fi
        break
    fi
done

exit 0
